-- fibonacci.mlp
-- Fibonacci sayısı hesaplar (özyinelemeli)
-- Beklenen: fibonacci(10) → 55

function fibonacci(n as numeric) -> numeric
    if n <= 1 then
        return n
    end_if
    return fibonacci(n - 1) + fibonacci(n - 2)
end_function

function main() -> numeric
    print(fibonacci(10))
    return 0
end_function
