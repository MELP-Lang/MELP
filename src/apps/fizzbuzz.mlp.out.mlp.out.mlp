-- fizzbuzz.mlp
-- 1'den 100'e FizzBuzz

function main() -> numeric
    numeric i = 1
    loop i <= 100
        if i mod 15 == 0 then
            print("FizzBuzz")
        else_if i mod 3 == 0 then
            print("Fizz")
        else_if i mod 5 == 0 then
            print("Buzz")
        else
            print(str(i))
        end_if
        i = i + 1
    end_loop
    return 0
end_function


