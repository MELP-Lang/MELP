{
  "comments": {
    "lineComment": "--",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "(?i)(캅SE_BA힇LANGI횉|D횜NG횥_BA힇LANGI횉|FONKSIYON|SINIF|I횉IN)\\s*$",
    "decreaseIndentPattern": "^\\s*SON\\s*$"
  },
  "wordPattern": "[a-zA-Z챌횉휓휒캇캅철횜힊힇체횥_][a-zA-Z챌횉휓휒캇캅철횜힊힇체횥0-9_]*"
}
