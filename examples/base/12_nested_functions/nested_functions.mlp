-- FEATURE: FUNCTION_DEF - Nested function calls
-- TASK: Demonstrate helper function + main function pattern

-- Helper function: adds two numbers
function add(numeric x; numeric y) as numeric
    return x + y
end_function

-- Helper function: multiplies two numbers
function multiply(numeric x; numeric y) as numeric
    return x * y
end_function

-- Helper function: uses other helpers
function calculate(numeric a; numeric b) as numeric
    numeric sum = add(a; b)
    numeric product = multiply(a; b)
    return add(sum; product)
end_function

-- Helper function: converts number to string and prints
function print_with_label(string label; numeric value) as numeric
    string msg = label + ": " + str(value)
    print(msg)
    return 0
end_function

-- Main function calls helpers
function main()
    -- Test 1: Simple helper call
    numeric r1 = add(10; 5)
    print_with_label("add(10;5)"; r1)

    -- Test 2: Another helper call
    numeric r2 = multiply(3; 7)
    print_with_label("multiply(3;7)"; r2)

    -- Test 3: Nested helper calls (calculate uses add and multiply)
    numeric r3 = calculate(4; 5)
    print_with_label("calculate(4;5)"; r3)

    -- Test 4: Chain of helper calls
    numeric step1 = add(2; 3)
    numeric step2 = multiply(step1; 4)
    numeric step3 = add(step2; 10)
    print_with_label("chained"; step3)
end_function
