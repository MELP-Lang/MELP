-- GÖREV 08: for_loop
-- For döngüsü: to, downto, step

function main()
    -- Ascending loop (to)
    for i = 1 to 5
        print(i)
    end_for

    -- Descending loop (downto)
    for j = 5 downto 1
        print(j)
    end_for

    -- With step (10'şer artış)
    for k = 0 to 50 step 10
        print(k)
    end_for

    -- Nested for loops
    for x = 1 to 3
        for y = 1 to 2
            print(x)
            print(y)
        end_for
    end_for
end_function
