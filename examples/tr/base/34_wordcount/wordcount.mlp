#lang turkish
sayısal fonksiyon kelime_say(metin text)
    sayısal count = 1
    sayısal i = 0
    döngü i < 10
        koşul text == "" ise
            count = 0
        koşul sonu
        i = i + 1
    döngü sonu
    döndür count
fonksiyon sonu

fonksiyon giriş()
    sayısal wc = kelime_say("hello world test")
    yazdır(wc)
fonksiyon sonu
