-- GÖREV 08: for_loop
-- For döngüsü: to, downto, step

function main()
    -- Ascending loop (to)
    loop i = 1 to 5
        print(i)
    end loop

    -- Descending loop (downto)
    loop j = 5 downto 1
        print(j)
    end loop

    -- With step (10'şer artış)
    loop k = 0 to 50 step 10
        print(k)
    end loop

    -- Nested for loops
    loop x = 1 to 3
        loop y = 1 to 2
            print(x)
            print(y)
        end loop
    end loop
end function
