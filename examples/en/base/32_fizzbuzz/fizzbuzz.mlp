function main()
    loop i = 1 to 20
        if i mod 15 == 0 then
            print(15)
        else
            if i mod 3 == 0 then
                print(3)
            else
                if i mod 5 == 0 then
                    print(5)
                else
                    print(i)
                end if
            end if
        end if
    end loop
end function
