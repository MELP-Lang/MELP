-- GOLDEN_TEST: test_03_random
-- DESC: Test random stdlib - seed, random_int bounds, random_bool
-- FEATURE: STDLIB-2-RANDOM
-- PHASE: Phase6

-- Seed for reproducibility
random_seed(42)

-- random_int(1;10) must be in [1..10]
numeric r = random_int(1; 10)
numeric r_lo = r >= 1
print(r_lo)
numeric r_hi = r <= 10
print(r_hi)

-- random_bool() must be 0 or 1
numeric b = random_bool()
numeric b_ok = b >= 0
print(b_ok)
numeric b_ok2 = b <= 1
print(b_ok2)

-- Expected: 1\n1\n1\n1
