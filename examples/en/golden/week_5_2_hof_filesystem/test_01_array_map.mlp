-- test_01_array_map.mlp
-- Expected output:
-- 5
-- 20
-- 40
-- 60
-- 80
-- 100

-- Create array [10, 20, 30, 40, 50]
numeric arr = __builtin_array_create()
__builtin_array_push(arr; 10)
__builtin_array_push(arr; 20)
__builtin_array_push(arr; 30)
__builtin_array_push(arr; 40)
__builtin_array_push(arr; 50)

-- Map: double each element
numeric double_fn = lambda(x) -> x * 2
numeric doubled = __builtin_array_map(arr; double_fn)

-- Print length and all mapped values
print(__builtin_array_length(doubled))
print(__builtin_array_get(doubled; 0))
print(__builtin_array_get(doubled; 1))
print(__builtin_array_get(doubled; 2))
print(__builtin_array_get(doubled; 3))
print(__builtin_array_get(doubled; 4))
-- Expected: 5\n20\n40\n60\n80\n100
