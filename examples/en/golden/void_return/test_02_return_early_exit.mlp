-- MKLP_TEST: void_early_exit
-- Expected: 5\n10
10
-- FEATURE: VOID_RETURN.md
-- CATEGORY: bug
-- ADDED_BY: YZ  DATE: 2026-03-05

function printPositive(numeric x)
  if x <= 0 then
    return
  end if
  print(x)
end function

function main()
  printPositive(5)
  printPositive(-3)
  printPositive(10)
end function
