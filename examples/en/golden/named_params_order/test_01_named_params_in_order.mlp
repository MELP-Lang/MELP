-- test_01_named_params_in_order.mlp
-- PHASE: 2 (Named Params)
-- EXPECTED: Ali\n25\n1
-- EKS-006: Tanım sırasıyla isimli parametre çağrısı (zaten çalışıyor)

function kullanici(string isim; numeric yas; boolean aktif)
    print(isim)
    print(yas)
    print(aktif)
end function

function main()
    kullanici(isim: "Ali"; yas: 25; aktif: true)
end function
