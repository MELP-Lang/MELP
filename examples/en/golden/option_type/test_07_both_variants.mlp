-- Option with both Some and None
-- Expected: 5\n99

enum Option<T>
  Some(T)
  None
end enum

Option has_value = Option.Some(5)
Option no_value = Option.None

match has_value
  case Some(v) -> print(v)
  case None -> print(0)
end match

match no_value
  case Some(v) -> print(0)
  case None -> print(99)
end match
