-- Multiple None values
-- Expected: 0\n0\n0

enum Option<T>
  Some(T)
  None
end enum

Option n1 = Option.None
Option n2 = Option.None
Option n3 = Option.None

match n1
  case Some(v) -> print(99)
  case None -> print(0)
end match

match n2
  case Some(v) -> print(99)
  case None -> print(0)
end match

match n3
  case Some(v) -> print(99)
  case None -> print(0)
end match
