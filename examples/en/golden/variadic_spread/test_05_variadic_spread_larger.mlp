-- test_05_variadic_many_args.mlp
-- PHASE: 3 (Variadic)
-- EXPECTED: 15
-- EKS-007: 5 argümanlı variadic toplama

numeric function toplam(numeric... sayilar)
    numeric s = 0
    for i in sayilar
        s = s + i
    end for
    return s
end function

function main()
    numeric r = toplam(1; 2; 3; 4; 5)
    print(r)    -- 1+2+3+4+5 = 15
    return 0
end function
