-- TEST: enum_fn_param
-- EXPECTED: green
-- FEATURE: ENUM.md
-- CATEGORY: bug
-- ADDED_BY: YZ  DATE: 2026-03-05

enum Color
  RED
  GREEN
  BLUE
end enum

string function colorName(numeric c)
  if c == Color.RED then
    return "red"
  end if
  if c == Color.GREEN then
    return "green"
  end if
  return "blue"
end function

function main()
  numeric x = Color.GREEN
  string name = colorName(x)
  print(name)
  return 0
end function
