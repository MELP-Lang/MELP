-- MKLP_TEST: hof_function_composition
-- EXPECTED: 16
-- FEATURE: HIGHER_ORDER_FUNCTIONS.md
-- CATEGORY: feature
-- ADDED_BY: YZ  DATE: 2026-03-05
-- NOTE: double(double(4)) = double(8) = 16

numeric function double(numeric x)
  return x * 2
end function

numeric function compose_double(numeric x)
  return double(double(x))
end function

function main()
  print(compose_double(4))
end function
