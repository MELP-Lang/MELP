-- Higher-Order Function Test - array_filter
-- Tests passing lambda predicate to array_filter

-- Create array
numeric arr = __builtin_array_create()
__builtin_array_push(arr; 1)
__builtin_array_push(arr; 2)
__builtin_array_push(arr; 3)
__builtin_array_push(arr; 4)
__builtin_array_push(arr; 5)
__builtin_array_push(arr; 6)

-- Filter: keep elements > 3
numeric is_big = lambda(x) -> x > 3
numeric filtered = __builtin_array_filter(arr; is_big)

-- Print length of filtered (should be 3: 4, 5, 6)
numeric len = __builtin_array_length(filtered)
print(len)

-- Print filtered values
print(__builtin_array_get(filtered; 0))
print(__builtin_array_get(filtered; 1))
print(__builtin_array_get(filtered; 2))
-- Expected: 3\n4\n5\n6
