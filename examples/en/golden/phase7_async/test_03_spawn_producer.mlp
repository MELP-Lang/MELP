-- GOLDEN_TEST: test_03_spawn_producer
-- FEATURE: STDLIB-ASYNC-3
-- PHASE: Phase7

function main()
  numeric ch = channel_create()
  spawn
    send(ch; 1)
    send(ch; 2)
    send(ch; 3)
  end_spawn
  numeric v1 = receive(ch)
  print(v1)
  numeric v2 = receive(ch)
  print(v2)
  numeric v3 = receive(ch)
  print(v3)
end function

-- Expected: 1\n2\n3
