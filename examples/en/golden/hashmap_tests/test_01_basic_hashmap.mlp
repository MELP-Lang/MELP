-- HashMap Basic Test
-- Tests hashmap create, set, get, has operations

-- Create hashmap
numeric map = __builtin_hashmap_create()

-- Set some key-value pairs
__builtin_hashmap_set(map; 1; 100)
__builtin_hashmap_set(map; 2; 200)
__builtin_hashmap_set(map; 3; 300)

-- Get values
numeric v1 = __builtin_hashmap_get(map; 1)
print(v1)

numeric v2 = __builtin_hashmap_get(map; 2)
print(v2)

numeric v3 = __builtin_hashmap_get(map; 3)
print(v3)

-- Check if key exists
numeric has1 = __builtin_hashmap_has(map; 1)
print(has1)

numeric has99 = __builtin_hashmap_has(map; 99)
print(has99)

-- Get size
numeric size = __builtin_hashmap_size(map)
print(size)
-- Expected: 100\n200\n300\n1\n0\n3
