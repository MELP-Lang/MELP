-- HashMap Delete Test
-- Tests hashmap delete operation

-- Create hashmap
numeric map = __builtin_hashmap_create()

__builtin_hashmap_set(map; 10; 1000)
__builtin_hashmap_set(map; 20; 2000)
__builtin_hashmap_set(map; 30; 3000)

-- Size before delete
numeric size1 = __builtin_hashmap_size(map)
print(size1)

-- Has key 20
numeric has20_before = __builtin_hashmap_has(map; 20)
print(has20_before)

-- Delete key 20
__builtin_hashmap_delete(map; 20)

-- Has key 20 after delete
numeric has20_after = __builtin_hashmap_has(map; 20)
print(has20_after)

-- Size after delete
numeric size2 = __builtin_hashmap_size(map)
print(size2)

-- Other keys still exist
numeric v10 = __builtin_hashmap_get(map; 10)
print(v10)
-- Expected: 3\n1\n0\n2\n1000
