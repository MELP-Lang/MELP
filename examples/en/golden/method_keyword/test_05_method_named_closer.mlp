-- test_05_method_named_closer.mlp
-- PHASE: 2 (Method Keyword)
-- Expected: 0
-- EKS-010: Birden fazla method ve net isimli kapatıcılar

struct Hesap
    numeric bakiye
end struct

method Hesap.yatir(numeric miktar) as void
    this.bakiye = this.bakiye + miktar
end_yatir

method Hesap.cek(numeric miktar) as boolean
    if this.bakiye >= miktar then
        this.bakiye = this.bakiye - miktar
        return true
    end if
    return false
end_cek

function main()
    Hesap h
    h.bakiye = 0
    h.yatir(100)
    h.cek(50)
    print(h.bakiye)   -- 50
end function
