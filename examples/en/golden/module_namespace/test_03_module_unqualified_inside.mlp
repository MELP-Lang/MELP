-- test_03_module_qualified_in_helper.mlp
-- PHASE: 2 (Module Namespace)
-- EXPECTED: 7
-- EKS-012: Modül nitelikli çağrı, yardımcı fonksiyon içinden yapılıyor

module MathUtils
    numeric function topla(numeric a; numeric b)
        return a + b
    end function
end module

numeric function hesapla(numeric x; numeric y)
    return MathUtils.topla(x; y)
end function

function main()
    numeric r = hesapla(3; 4)
    print(r)
end function
