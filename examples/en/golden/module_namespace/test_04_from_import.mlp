-- test_04_from_import.mlp
-- PHASE: 2 (Module Namespace)
-- EXPECTED: 7
-- EKS-012: from ... import sözdizimi

module MathUtils
    numeric function topla(numeric a; numeric b)
        return a + b
    end function
end module

from MathUtils import topla

function main()
    numeric r = topla(3; 4)
    print(r)
end function
