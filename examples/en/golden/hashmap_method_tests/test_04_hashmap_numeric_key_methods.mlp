-- test_04_hashmap_numeric_key_methods.mlp
-- PHASE: 2 (HashMap Methods)
-- EXPECTED: 1\n0
-- EKS-014: Numerik anahtarlı hashmap .has() / .delete()

function main()
    hashmap<numeric; string> veri = {}
    veri[1] = "bir"
    veri[2] = "iki"

    print(veri.has(1))    -- 1
    veri.delete(1)
    print(veri.has(1))    -- 0
end function
