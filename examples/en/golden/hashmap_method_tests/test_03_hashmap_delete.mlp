-- test_03_hashmap_delete.mlp
-- PHASE: 2 (HashMap Methods)
-- EXPECTED: 1\n0
-- EKS-014: Hashmap .delete() metod sözdizimi

function main()
    hashmap<string; numeric> puan = {}
    puan["ali"] = 95

    print(puan.has("ali"))   -- 1
    puan.delete("ali")
    print(puan.has("ali"))   -- 0
end function
