-- test_05_hashmap_methods_chain.mlp
-- PHASE: 2 (HashMap Methods)
-- EXPECTED: 2\nali mevcut\n1
-- EKS-014: .has() + .size() + .delete() kombine kullanım

function main()
    hashmap<string; numeric> puan = {}
    puan["ali"] = 95
    puan["veli"] = 80

    print(puan.size())         -- 2

    if puan.has("ali") then
        print("ali mevcut")
    end if

    puan.delete("veli")
    print(puan.size())         -- 1
end function
